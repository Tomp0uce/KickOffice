{
  "name": "office-word-diff",
  "version": "1.0.0",
  "description": "Apply word-level text diffs to Microsoft Word using Office.js API while preserving formatting and enabling granular track changes",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "lib",
    "src"
  ],
  "scripts": {
    "build": "rollup -c && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "office-js",
    "microsoft-word",
    "word-addin",
    "word-api",
    "diff",
    "patch",
    "diff-match-patch",
    "track-changes",
    "office-add-in",
    "word-javascript-api",
    "formatting-preservation",
    "tracked-changes"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/office-word-diff.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/office-word-diff/issues"
  },
  "homepage": "https://github.com/yourusername/office-word-diff#readme",
  "peerDependencies": {
    "@microsoft/office-js": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "@microsoft/office-js": {
      "optional": true
    }
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@types/office-js": "^1.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
