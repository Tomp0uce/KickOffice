# KickOffice Frontend Configuration
# Copy this file to .env and fill in the values

# Backend URL (used at build time)
VITE_BACKEND_URL=http://localhost:3003

# HTTP request timeout in milliseconds (default: 180000 = 3 min)
# VITE_REQUEST_TIMEOUT_MS=180000

# Enable verbose Office.js insertion logging (default: false)
# VITE_VERBOSE_LOGGING=false
