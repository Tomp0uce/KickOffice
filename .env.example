# IH2: Replace with your actual server IP (e.g., 192.168.x.x, localhost, or your domain)
SERVER_IP=localhost
FRONTEND_PORT=3002
BACKEND_PORT=3003
APP_VERSION=
VITE_REQUEST_TIMEOUT_MS=45000

# Optional: Public URLs for DuckDNS/HTTPS via Reverse Proxy
# IMPORTANT: Do NOT include trailing slashes (/) or /api suffixes.
# The application automatically sets up its own paths.
# IH3: Replace with your actual DuckDNS domain or public URL
PUBLIC_FRONTEND_URL=https://your-domain.duckdns.org
PUBLIC_BACKEND_URL=https://your-domain.duckdns.org
